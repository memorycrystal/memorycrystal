# Template — keys with ${...} are filled at up-time.
CRYSTAL_BACKEND=local

# Self-hosted Convex (host-only; NOT pushed to Convex deployment env)
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=${GENERATED_ADMIN_KEY}

# Client RPC URL (port 3210)
CONVEX_URL=http://127.0.0.1:3210
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Client HTTP-actions URL (port 3211)
CRYSTAL_CONVEX_URL=http://127.0.0.1:3211
CRYSTAL_CONVEX_SITE_URL=http://127.0.0.1:3211
MEMORY_CRYSTAL_API_URL=http://127.0.0.1:3211
MEMORY_CRYSTAL_API_KEY=local-dev-bearer-token

# Side-effect guards
CRYSTAL_LOCAL_LLM_STUB=1
CRYSTAL_EMAIL_DRY_RUN=1

# NOTE: JWT_PRIVATE_KEY and JWKS are NOT written to host env.
# They are pushed directly into the Convex deployment environment by
# scripts/convex-local-auth-keys.ts. CONVEX_SITE_URL is also deployment-env only.
